# ═══════════════════════════════════════════════════════════════════════════════
# Veloce Engine — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Veloce Engine
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true

# ─── Server ───────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins. Use * only in development.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── File Upload ──────────────────────────────────────────────────────────────
# Maximum upload size in bytes (default: 100MB)
MAX_UPLOAD_SIZE_BYTES=104857600
UPLOAD_DIR=data/uploads

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=logs/veloce.log

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
